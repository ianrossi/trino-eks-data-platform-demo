apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: streaming-demo
  namespace: argocd
spec:
  project: default
  source:
    repoURL: https://github.com/ianrossi/trino-eks-data-platform-demo.git
    targetRevision: HEAD
    path: kubernetes/streaming
  destination:
    server: https://kubernetes.default.svc
    namespace: streaming
  syncPolicy:
    automated:
      prune: true
      selfHeal: true
    syncOptions:
      - CreateNamespace=true
