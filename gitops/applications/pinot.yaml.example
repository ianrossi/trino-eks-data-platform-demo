apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: pinot
  namespace: argocd
spec:
  project: default
  source:
    repoURL: https://raw.githubusercontent.com/apache/pinot/master/helm
    chart: pinot
    targetRevision: 1.0.0
    helm:
      valuesObject:
        image:
          tag: "1.0.0"
          pullPolicy: IfNotPresent
        cluster:
          name: pinot-demo
        controller:
          external:
            enabled: false
          jvmOpts: "-XX:ActiveProcessorCount=2 -Xms256M -Xmx512M -XX:+UseG1GC -Djute.maxbuffer=4000000"
          persistence:
            enabled: false
            size: 1Gi
            storageClass: gp2
          resources:
            requests:
              cpu: "250m"
              memory: 768Mi
            limits:
              memory: 768Mi
          nodeSelector:
            workload-class: data
        broker:
          external:
            enabled: false
          jvmOpts: "-XX:ActiveProcessorCount=2 -Xms256M -Xmx512M -XX:+UseG1GC -Djute.maxbuffer=4000000"
          resources:
            requests:
              cpu: "250m"
              memory: 768Mi
            limits:
              memory: 768Mi
          nodeSelector:
            workload-class: data
        server:
          jvmOpts: "-Xms512M -Xmx768M -XX:+UseG1GC -Djute.maxbuffer=4000000"
          persistence:
            enabled: false
            size: 2Gi
            storageClass: gp2
          resources:
            requests:
              cpu: "500m"
              memory: 1Gi
            limits:
              memory: 1Gi
          nodeSelector:
            workload-class: data
        minion:
          enabled: false
          replicaCount: 0
          nodeSelector:
            workload-class: data
        minionStateless:
          enabled: false
          replicaCount: 0
        zookeeper:
          persistence:
            enabled: false
            storageClass: gp2
            size: 1Gi
            data:
              size: 1Gi
              storageClass: gp2
            datalog:
              size: 1Gi
              storageClass: gp2
          heapSize: "512"
          resources:
            requests:
              cpu: "250m"
              memory: 768Mi
            limits:
              memory: 768Mi
          nodeSelector:
            workload-class: data
  destination:
    server: https://kubernetes.default.svc
    namespace: pinot
  syncPolicy:
    automated:
      prune: true
      selfHeal: true
    syncOptions:
      - CreateNamespace=true
      - Replace=true
