apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: karpenter-nodepool
  namespace: argocd
spec:
  project: default
  source:
    repoURL: https://github.com/ianrossi/trino-eks-data-platform-demo.git
    targetRevision: HEAD
    path: gitops/apps/karpenter-nodepool
  destination:
    server: https://kubernetes.default.svc
    namespace: default
  syncPolicy:
    automated:
      prune: true
      selfHeal: true
    syncOptions:
      - CreateNamespace=true
